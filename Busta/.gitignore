models_artifacts/confusion_matrix.csv
models_artifacts/benchmark/
models_artifacts/eval/

# Keep the directory structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!models_artifacts/.gitkeep

